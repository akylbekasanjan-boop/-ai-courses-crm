generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  team_lead
  sales_manager
}

enum LeadSource {
  website
  instagram
  telegram
  youtube
  referral
  cold_call
  other
  ads
  whatsapp
}

enum LeadStatus {
  new
  in_progress
  no_answer
  thinking
  rejected
  paid
}

enum DealStatus {
  active
  won
  lost
}

enum TaskType {
  call
  meeting
  email
  follow_up
  other
}

enum TaskStatus {
  pending
  in_progress
  done
  overdue
}

enum Priority {
  low
  medium
  high
}

enum ActivityType {
  stage_change
  call
  email
  comment
  task_completed
  document_uploaded
  lead_assigned
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  role         Role     @default(sales_manager)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  activities    Activity[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  phone           String?
  email           String?
  source          LeadSource
  status          LeadStatus @default(new)
  comment         String?
  tags            String[]
  assignedToId    String
  assignedTo      User       @relation(fields: [assignedToId], references: [id])
  deal            Deal?
  activities      Activity[]
  tasks           Task[]
  courseInterests Course[]   @relation("LeadCourses")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  convertedAt     DateTime?
}

model Deal {
  id                String        @id @default(cuid())
  title             String
  leadId            String?       @unique
  lead              Lead?         @relation(fields: [leadId], references: [id])
  contactId         String?
  contact           Contact?      @relation(fields: [contactId], references: [id])
  stageId           String
  stage             PipelineStage @relation(fields: [stageId], references: [id])
  amount            Float
  currency          String        @default("RUB")
  courseId          String?
  course            Course?       @relation(fields: [courseId], references: [id])
  assignedToId      String
  assignedTo        User          @relation(fields: [assignedToId], references: [id])
  probability       Int           @default(50)
  expectedCloseDate DateTime?
  status            DealStatus    @default(active)
  lostReason        String?
  tags              String[]
  activities        Activity[]
  tasks             Task[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  closedAt          DateTime?
}

model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String?
  phones    String[]
  emails    String[]
  telegram  String?
  instagram String?
  company   String?
  position  String?
  notes     String?
  tags      String[]
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id     String  @id @default(cuid())
  name   String
  color  String  @default("#6366f1")
  order  Int
  isWon  Boolean @default(false)
  isLost Boolean @default(false)
  deals  Deal[]
}

model Course {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  currency    String   @default("RUB")
  duration    String?
  format      String   @default("online")
  level       String   @default("beginner")
  isActive    Boolean  @default(true)
  tags        String[]
  deals       Deal[]
  leads       Lead[]   @relation("LeadCourses")
}

model Task {
  id           String     @id @default(cuid())
  type         TaskType
  title        String
  description  String?
  assignedToId String
  assignedTo   User       @relation(fields: [assignedToId], references: [id])
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id])
  dealId       String?
  deal         Deal?      @relation(fields: [dealId], references: [id])
  dueDate      DateTime
  status       TaskStatus @default(pending)
  priority     Priority   @default(medium)
  result       String?
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id])
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id])
  metadata    Json?
  createdAt   DateTime     @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
